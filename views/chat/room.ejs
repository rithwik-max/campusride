<%- layout('layouts/boilerplate') %>

<% const sessionId = session._id.toString(); %>
<% const userId = currentUser._id.toString(); %>
<% const userName = currentUser.name; %>

<div class="page-header" style="margin-bottom:16px;">
  <div>
    <h1 class="page-title" style="font-size:1.4rem;">💬 Chat Room</h1>
    <p class="page-subtitle">Session expires 24 hrs after creation</p>
  </div>
  <a href="/chat" class="btn btn-ghost btn-sm"><i class="bi bi-arrow-left"></i> Back</a>
</div>

<div class="chat-wrapper">

  <!-- Chat main -->
  <div class="glass-card chat-main" style="display:flex; flex-direction:column;">

    <div class="chat-header">
      <div class="chat-header-info">
        <h3>🚉 Travel Group Chat</h3>
        <div class="participant-list">
          <% for (let p of session.participants) { %>
            <span class="participant-chip">
              <%= p.name %> <% if (p._id.toString() === userId) { %>(you)<% } %>
            </span>
          <% } %>
        </div>
      </div>
      <% if (!isExpired) { %>
        <span class="session-active" style="font-size:0.8rem;"><i class="bi bi-circle-fill" style="font-size:0.45rem;"></i> Active</span>
      <% } else { %>
        <span class="session-expired" style="font-size:0.8rem;"><i class="bi bi-clock-history"></i> Expired</span>
      <% } %>
    </div>

    <% if (isExpired) { %>
      <div class="expired-banner" style="margin:12px 20px 0;">
        <i class="bi bi-lock-fill"></i> This chat has expired. You can no longer send messages. (24hr limit reached)
      </div>
    <% } %>

    <div class="chat-messages" id="chatMessages">
      <% if (messages.length === 0) { %>
        <div style="text-align:center; color:var(--text-muted); font-size:0.88rem; margin: auto;">
          <i class="bi bi-chat" style="font-size:2rem; opacity:0.3; display:block; margin-bottom:8px;"></i>
          No messages yet. Say hi! 
        </div>
      <% } %>
      <% for (let msg of messages) { %>
        <div class="msg-bubble <%= msg.sender.toString() === userId ? 'me' : 'other' %>">
          <% if (msg.sender.toString() !== userId) { %>
            <span class="msg-name"><%= msg.senderName %></span>
          <% } %>
          <div class="msg-content"><%= msg.message %></div>
          <span class="msg-time">
            <%= new Date(msg.createdAt).toLocaleTimeString('en-IN', {hour:'2-digit', minute:'2-digit'}) %>
          </span>
        </div>
      <% } %>
    </div>

    <div class="chat-input-area">
      <input
        type="text"
        id="msgInput"
        class="chat-input"
        placeholder="<%= isExpired ? 'Chat has expired...' : 'Type a message...' %>"
        <%= isExpired ? 'disabled' : '' %>
        autocomplete="off"
      />
      <button class="chat-send-btn" id="sendBtn" <%= isExpired ? 'disabled' : '' %>>
        <i class="bi bi-send-fill"></i>
      </button>
    </div>
  </div>

  <!-- Auto sidebar -->
  <div class="auto-sidebar">
    <div class="glass-card auto-panel">
      <h4>🛺 Auto Driver Numbers</h4>
      <p style="font-size:0.78rem; color:var(--text-muted); margin-bottom:14px;">
        Contact these local auto drivers for your ride:
      </p>
      <% for (let a of autoContacts) { %>
        <div class="auto-item">
          <span class="auto-icon">🛺</span>
          <div>
            <div class="auto-name"><%= a.name %></div>
            <div class="auto-num">📞 <%= a.number %></div>
          </div>
        </div>
      <% } %>
      <p style="font-size:0.72rem; color:var(--text-muted); margin-top:10px;">
        <i class="bi bi-info-circle"></i> These are local numbers near your college. Call to book in advance.
      </p>
    </div>

    <div class="glass-card auto-panel">
      <h4>ℹ️ Session Info</h4>
      <div style="font-size:0.82rem; color:var(--text-muted); line-height:1.7;">
        <div><i class="bi bi-clock" style="color:var(--accent);"></i> Expires: <%= new Date(session.expiresAt).toLocaleString('en-IN') %></div>
        <div style="margin-top:6px;"><i class="bi bi-shield-lock" style="color:var(--accent2);"></i> Chat auto-locks after 24 hours</div>
      </div>
    </div>
  </div>

</div>
<script src="/socket.io/socket.io.js"></script>
<script>
  const SESSION_ID = "<%= sessionId %>";
  const USER_ID = "<%= userId %>";
  const USER_NAME = "<%= userName %>";
  const IS_EXPIRED = <%= isExpired %>;
</script>
<script src="/js/chat.js"></script>