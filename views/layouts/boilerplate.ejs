<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title><%= typeof title !== 'undefined' ? title : "CampusRide" %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>

  <div class="bg-blobs">
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
    <div class="blob blob-3"></div>
  </div>

  <% if (typeof currentUser !== 'undefined' && currentUser) { %>
  <nav class="navbar">
    <a href="/announcements" class="nav-brand">
      <i class="bi bi-train-front-fill"></i> CampusRide
    </a>
    <div class="nav-links">
      <a href="/announcements" class="nav-link"><i class="bi bi-grid-fill"></i> Board</a>
      <a href="/announcements/new" class="nav-link"><i class="bi bi-plus-circle-fill"></i> Post Ride</a>
      <a href="/announcements/my" class="nav-link"><i class="bi bi-person-lines-fill"></i> My Rides</a>
      <a href="/chat" class="nav-link"><i class="bi bi-chat-dots-fill"></i> Chats</a>
      <a href="/user/profile" class="nav-link nav-avatar">
        <span class="avatar-dot"><%= currentUser.name[0].toUpperCase() %></span>
      </a>
      <a href="/logout" class="nav-link nav-logout"><i class="bi bi-box-arrow-right"></i></a>
    </div>
  </nav>
  <% } %>

  <main class="main-content">
    <% if (success && success.length > 0) { %>
      <div class="flash flash-success"><i class="bi bi-check-circle-fill"></i> <%= success[0] %></div>
    <% } %>
    <% if (error && error.length > 0) { %>
      <div class="flash flash-error"><i class="bi bi-exclamation-triangle-fill"></i> <%= error[0] %></div>
    <% } %>
    <%- body %>
  </main>
  <script src="/js/main.js"></script>
</body>
</html>
