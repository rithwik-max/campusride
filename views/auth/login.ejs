<%- layout('layouts/boilerplate') %>

<div class="auth-wrapper">
  <div class="glass-card auth-card">
    <div class="auth-logo">
      <div style="font-size:2.8rem; margin-bottom:8px;">🚌</div>
      <h1>CampusRide</h1>
      <p>Split the fare, share the journey</p>
    </div>

    <form action="/login" method="POST">
      <div class="form-group">
        <label class="form-label">College Email</label>
        <input type="email" name="email" class="form-input" placeholder="av.sc.u4cse24xxx@example.com" required />
      </div>
      <div class="form-group">
        <label class="form-label">Password</label>
        <input type="password" name="password" class="form-input" placeholder="••••••••" required />
      </div>
      <button type="submit" class="btn btn-primary btn-full" style="margin-top:8px;">
        <i class="bi bi-box-arrow-in-right"></i> Login
      </button>
    </form>

    <p style="text-align:center; margin-top:22px; font-size:0.88rem; color:var(--text-muted);">
      Don't have an account? <a href="/register" style="color:var(--accent); font-weight:600;">Sign Up</a>
    </p>
  </div>
</div>
