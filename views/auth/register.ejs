<%- layout('layouts/boilerplate') %>

<div class="auth-wrapper">
  <div class="glass-card auth-card" style="max-width:500px;">
    <div class="auth-logo">
      <div style="font-size:2.4rem; margin-bottom:8px;">✨</div>
      <h1>Create Account</h1>
      <p>Only verified CSE 2024 students can join</p>
    </div>

    <form action="/register" method="POST">
      <div class="form-group">
        <label class="form-label">Full Name</label>
        <input type="text" name="name" class="form-input" placeholder="Your full name" required />
      </div>

      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Email</label>
          <input type="email" name="email" class="form-input" placeholder="your@email.com" required />
        </div>
        <div class="form-group">
          <label class="form-label">Phone</label>
          <input type="tel" name="phone" class="form-input" placeholder="10-digit number" required />
        </div>
      </div>

      <div class="form-group">
        <label class="form-label">Roll Number</label>
        <input type="text" name="rollNumber" class="form-input" placeholder="av.sc.u4cse24101" required />
        <small style="color:var(--text-muted); font-size:0.78rem; margin-top:5px; display:block;">
          Must be between av.sc.u4cse24101 – av.sc.u4cse24151
        </small>
      </div>

      <div class="form-group">
        <label class="form-label">Password</label>
        <input type="password" name="password" class="form-input" placeholder="At least 6 characters" required />
      </div>

      <button type="submit" class="btn btn-primary btn-full" style="margin-top:8px;">
        <i class="bi bi-person-plus-fill"></i> Create Account
      </button>
    </form>

    <p style="text-align:center; margin-top:22px; font-size:0.88rem; color:var(--text-muted);">
      Already have an account? <a href="/login" style="color:var(--accent); font-weight:600;">Login</a>
    </p>
  </div>
</div>
